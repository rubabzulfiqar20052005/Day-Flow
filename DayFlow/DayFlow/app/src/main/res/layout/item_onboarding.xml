<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSlide"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0F172A"
            android:padding="18dp">

            <!-- Light logo watermark -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-10dp"
                android:src="@drawable/dayflow_logo"
                android:alpha="0.10"
                android:contentDescription="logo watermark" />

            <ImageView
                android:id="@+id/slideIcon"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:src="@drawable/dayflow_logo"
                android:contentDescription="Slide Icon"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/onTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Day Flow"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="22sp"
                android:layout_below="@id/slideIcon" />

            <TextView
                android:id="@+id/onDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dayflow is a smart daily planning app designed to help you organize your tasks, manage your time, and stay focused throughout the day. With a simple and intuitive interface, Dayflow lets you plan your schedule, set priorities, and track progress effortlessly. Whether you’re managing work, studies, or personal goals, Dayflow helps you stay productive, reduce stress, and flow smoothly through your day"
                android:textColor="#BBD5FF"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:layout_below="@id/onTitle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Swipe to continue →"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:layout_alignParentBottom="true" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>

