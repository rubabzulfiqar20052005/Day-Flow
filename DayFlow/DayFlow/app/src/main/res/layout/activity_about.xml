<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <View
        android:id="@+id/topStrip"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:background="#D9C9FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/topStrip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            app:tint="#111827"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About DayFlow"
            android:textColor="#111827"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Card (no CardView dependency) -->
    <LinearLayout
        android:id="@+id/cardAbout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_card"
        android:padding="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/dayflow_logo"
                    android:contentDescription="DayFlow Logo" />

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DayFlow"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:textColor="#111827"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version 1.0"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvAboutTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvAboutDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DayFlow is a simple and smart day planner to help you manage tasks, habits, notes and keep your day productive."
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvDevTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Developer"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvDeveloper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Developer: Alina Maqsood"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contact: alinamaqsood82@gmail.com"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
