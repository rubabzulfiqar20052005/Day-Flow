<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp"
    android:paddingTop="34dp">

    <!-- Top Row: Logo + Skip -->
    <ImageView
        android:id="@+id/topLogo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/dayflow_logo"
        android:contentDescription="DayFlow Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Big Title -->
    <TextView
        android:id="@+id/tvOnTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Welcome to DayFlow"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="28sp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/topLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvOnSub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Make your day smooth and productive."
        android:textColor="#BBD5FF"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvOnTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Pager -->

    <!-- Bottom Bar -->

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingPager"
        android:layout_width="366dp"
        android:layout_height="433dp"
        android:layout_marginTop="14dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOnSub"
        app:layout_constraintVertical_bias="0.0" />

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dots/Indicators simple placeholders -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="22dp"
                android:layout_height="6dp"
                android:background="#3B82F6"
                android:alpha="0.95"
                android:layout_marginEnd="6dp" />

            <View
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:background="#FFFFFF"
                android:alpha="0.35"
                android:layout_marginEnd="6dp" />

            <View
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:background="#FFFFFF"
                android:alpha="0.35" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSkip"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Skip"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_primary_btn" />

            <View
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Next"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_primary_btn" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

